# ------------------------------------------------------------
# App runtime
# ------------------------------------------------------------

# HTTP port for the Node server
PORT=3000

# Public base URL of the app (used in email links)
# Example: https://your-domain.com
APP_BASE_URL=https://your-domain.com

# Retry payment link validity in seconds (default: 7 days)
RETRY_PAYMENT_LINK_TTL_SECONDS=604800

# SQLite daily backup scheduler (runs automatically at local midnight)
DB_BACKUP_ENABLED=true

# Backup directory path
# Defaults to ./data/backups if left empty in code
DB_BACKUP_DIR=./data/backups

# Delete backups older than this many days
DB_BACKUP_RETENTION_DAYS=30

# Environment mode
NODE_ENV=production

# Trust X-Forwarded-For header from reverse proxy/load balancer
# Set true only when running behind a trusted proxy (Railway/NGINX/Cloudflare, etc.)
TRUST_PROXY=true

# ------------------------------------------------------------
# Admin authentication
# ------------------------------------------------------------

# Initial admin password for first boot.
# It is hashed and stored in SQLite (app_settings), then can be changed on /admin.
ADMIN_PASSWORD=admin123

# Secret used to sign admin session cookies
# Optional: if omitted, app generates one at startup and stores it in SQLite app_settings.
# Recommended in production: set a long random value explicitly.
ADMIN_SESSION_SECRET=

# Rate limit for public registration endpoint (/api/register)
REGISTRATION_RATE_LIMIT_COUNT=30
REGISTRATION_RATE_LIMIT_WINDOW_MS=600000

# ------------------------------------------------------------
# Transactional email (Brevo)
# ------------------------------------------------------------

# Email provider switch
# Set to "brevo" to enable sending
# Leave empty to disable email sending
EMAIL_PROVIDER=brevo

# Brevo API key
BREVO_API_KEY=

# Sender email address shown in outgoing emails
EMAIL_FROM=no-reply@your-domain.com

# Sender display name shown in outgoing emails
EMAIL_FROM_NAME=Ishido Sensei - Summer Seminar

# Optional admin notification recipient for new registrations
# Leave empty to disable admin notification email
ADMIN_NOTIFY_EMAIL=you@example.com

# Max recipients allowed in one admin bulk email operation
ADMIN_EMAIL_MAX_RECIPIENTS=500

# Rate limit for admin bulk email send endpoint (/api/admin/email/send)
ADMIN_EMAIL_RATE_LIMIT_COUNT=20
ADMIN_EMAIL_RATE_LIMIT_WINDOW_MS=600000

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------

# Stripe secret key (required for Checkout session creation)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (required for /api/stripe/webhook verification)
STRIPE_WEBHOOK_SECRET=

# Optional override URLs for Stripe redirect flow
# If empty, APP_BASE_URL/payment-success and /payment-cancel are used
# The app auto-adds session_id={CHECKOUT_SESSION_ID} to success URL if missing.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# ------------------------------------------------------------
# Szamlazz.hu
# ------------------------------------------------------------

# Enable Szamlazz.hu invoice creation
SZAMLAZZ_ENABLED=false

# Agent key from Szamlazz.hu
SZAMLAZZ_AGENT_KEY=

# API endpoint (normally do not change)
SZAMLAZZ_API_URL=https://www.szamlazz.hu/szamla/

# Invoice language code used in Szamlazz.hu request
SZAMLAZZ_INVOICE_LANGUAGE=en

# Payment method text as configured in Szamlazz.hu
SZAMLAZZ_PAYMENT_METHOD=Bankkártya

# VAT key/rate (for example: 27, 18, 5, 0, AAM, TAM, EU, ...)
SZAMLAZZ_AFAKULCS=0

# true: e-invoice, false: paper invoice mode
SZAMLAZZ_ESZAMLA=false

# true: Szamlazz.hu sends invoice email to buyer
SZAMLAZZ_SEND_EMAIL=false

# Mark invoice as paid at creation time
SZAMLAZZ_SET_PAID=true

# Free text comment on invoice
SZAMLAZZ_COMMENT=Ishido Sensei - Summer Seminar 2026

# Prefix used for external invoice identifier (followed by registration ID)
SZAMLAZZ_EXTERNAL_ID_PREFIX=camp-

# HTTP timeout for Szamlazz.hu request in milliseconds
SZAMLAZZ_REQUEST_TIMEOUT_MS=15000

# ------------------------------------------------------------
# Deployment note (not read by app directly)
# ------------------------------------------------------------

# Railway/Nixpacks Node version pin (build/runtime platform variable)
# NIXPACKS_NODE_VERSION=22
